# Database connection (use postgresql+asyncpg:// or postgresql://)
DATABASE_URL=postgresql+asyncpg://edubridge:edubridge@db:5432/edubridge

# For external Postgres (e.g., Supabase):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# Debug mode
DEBUG=false

# ===================
# LTI 1.3 Configuration
# ===================

# Your tool's public URL (your Render URL)
APP_BASE_URL=https://your-app.onrender.com

# Client ID from LMS registration
LTI_CLIENT_ID=your-client-id

# Issuer - identifies the LMS platform
# For MoodleCloud: https://your-site.moodlecloud.com
LTI_ISSUER=https://your-site.moodlecloud.com

# Authorization endpoint - where to redirect for OIDC auth
# For MoodleCloud: https://your-site.moodlecloud.com/mod/lti/auth.php
LTI_AUTHORIZATION_ENDPOINT=https://your-site.moodlecloud.com/mod/lti/auth.php

# JWKS URL - where to fetch public keys for JWT verification
# For MoodleCloud: https://your-site.moodlecloud.com/mod/lti/certs.php
LTI_JWKS_URL=https://your-site.moodlecloud.com/mod/lti/certs.php

# Deployment ID from LMS registration
LTI_DEPLOYMENT_ID=1
